# URL de la aplicación (necesaria para Next.js)
# En desarrollo: http://localhost:3000
# En producción: tu dominio real
NEXTAUTH_URL=http://localhost:3000

# ===============================================
# VARIABLES PARA ENVÍO DE EMAILS (OPCIONALES)
# ===============================================
# Estas variables son necesarias SOLO si querés que el formulario
# envíe emails automáticamente. Si no las configurás, el formulario
# seguirá funcionando pero NO enviará emails.

# ABACUSAI_API_KEY=tu_api_key_aqui
# WEB_APP_ID=tu_app_id_aqui
# NOTIF_ID_CONSULTA_DE_EVENTO=tu_notif_id_aqui

# ===============================================
# NOTA IMPORTANTE
# ===============================================
# Si desplegás en Vercel/Netlify/otro hosting:
# - Copia estas variables en la configuración de tu plataforma
# - Cambia NEXTAUTH_URL por tu dominio real
# - Las variables de email son opcionales, podés configurarlas después
