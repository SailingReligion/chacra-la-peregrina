# ============================================================================
#  Variables de entorno — Chacra La Peregrina (GitHub Pages + Web3Forms)
# ============================================================================
#
#  Este archivo muestra las variables de entorno opcionales para el proyecto.
#  La mayoría NO son necesarias para que el sitio funcione.
#
#  Para desarrollo local, copiá este archivo:
#    cp .env.example .env.local
#
#  Y configurá solo las que necesites.
#
# ============================================================================

# ----------------------------------------------------------------------------
#  FORMULARIO DE CONTACTO — Web3Forms (OBLIGATORIO para que funcionen los emails)
# ----------------------------------------------------------------------------
#
#  El formulario envía consultas a tu email usando Web3Forms (gratis).
#
#  PASOS:
#   1. Registrate en https://web3forms.com (gratis, sin tarjeta)
#   2. Creá un "Access Key" y poné como email de destino: ebarlocco@gmail.com
#   3. Copiá la clave que te generan y pegala acá:
#
NEXT_PUBLIC_WEB3FORMS_KEY=tu_access_key_de_web3forms_aqui
#
#  ALTERNATIVA: Si preferís no usar .env, podés pegar la clave directamente
#  en el archivo components/sections/contact.tsx (línea ~31).
#
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
#  URL DEL SITIO (solo para metadata/SEO)
# ----------------------------------------------------------------------------
#
#  Se usa en robots.txt, sitemap.xml y metadata.
#  En GitHub Pages SIN dominio propio: https://sailingreligion.github.io/chacra-la-peregrina
#  Con dominio propio: https://chacralaperegrina.com
#
NEXT_PUBLIC_SITE_URL=https://chacralaperegrina.com

# ----------------------------------------------------------------------------
#  BASE PATH (solo si usás GitHub Pages SIN dominio propio)
# ----------------------------------------------------------------------------
#
#  Cuando el sitio vive en una subcarpeta tipo:
#    https://sailingreligion.github.io/chacra-la-peregrina
#  Next.js necesita saber el "prefijo" para armar bien los links y assets.
#
#  Descomentá esta línea:
# NEXT_PUBLIC_BASE_PATH=/chacra-la-peregrina
#
#  Si conectás un dominio propio (ej: chacralaperegrina.com), COMENTÁ o ELIMINÁ
#  esta variable para que el sitio funcione en la raíz.
#
# ----------------------------------------------------------------------------

# ============================================================================
#  VARIABLES INTERNAS (no tocar, solo para configuración de build)
# ============================================================================

# Modo de compilación (para GitHub Actions):
# NEXT_OUTPUT_MODE=export

# Directorio de build (default: .next):
# NEXT_DIST_DIR=.next
